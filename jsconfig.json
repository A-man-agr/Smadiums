{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2021",
    "checkJs": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "./src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.js", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
